{
  "framework": "nextjs",
  "buildCommand": "next build",
  "outputDirectory": ".next",
  "installCommand": "npm install",
  "regions": ["iad1"],
  "crons": [
    {
      "path": "/api/cron/scrape-notices",
      "schedule": "0 0 * * *"
    },
    {
      "path": "/api/cron/scrape-current-affairs",
      "schedule": "0 6 * * *"
    },
    {
      "path": "/api/cron/generate-predictions",
      "schedule": "0 0 * * 0"
    }
  ]
}
